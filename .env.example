# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=secret
DATABASE_URL=postgresql://agentarena:secret@localhost:5432/agentarena

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── LLM Keys (optional — enables AI-powered failure analysis) ─────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Paths ─────────────────────────────────────────────────────────────────────
P1_PATH=./p1

# ── Scoring Weights (must sum to 1.0) ─────────────────────────────────────────
WEIGHT_GOAL_COMPLETION=0.30
WEIGHT_HALLUCINATION=0.20
WEIGHT_SAFETY=0.20
WEIGHT_ADVERSARIAL=0.20
WEIGHT_COST=0.10

# ── Elo ───────────────────────────────────────────────────────────────────────
ELO_K_FACTOR=32
ELO_INITIAL_RATING=1200
